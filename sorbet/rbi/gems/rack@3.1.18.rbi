  # pkg:gem/rack#lib/rack/events.rb:72
  def on_finish(req, res); end

  # pkg:gem/rack#lib/rack/events.rb:69
  def on_send(req, res); end

  # pkg:gem/rack#lib/rack/events.rb:63
  def on_start(req, res); end
end

