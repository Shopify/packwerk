# Context allows the use of a compatible middleware at different points
# in a request handling stack. A compatible middleware must define
# #context which should take the arguments env and app. The first of which
# would be the request environment. The second of which would be the rack
# application that the request would be forwarded to.
#
# pkg:gem/rack#lib/rack/utils.rb:478
class Rack::Utils::Context
  # pkg:gem/rack#lib/rack/utils.rb:481
  def initialize(app_f, app_r); end

  # pkg:gem/rack#lib/rack/utils.rb:479
  def app; end

  # pkg:gem/rack#lib/rack/utils.rb:486
  def call(env); end

  # pkg:gem/rack#lib/rack/utils.rb:494
  def context(env, app = T.unsafe(nil)); end

  # pkg:gem/rack#lib/rack/utils.rb:479
  def for; end

  # pkg:gem/rack#lib/rack/utils.rb:490
  def recontext(app); end
end

